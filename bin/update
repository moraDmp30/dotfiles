#!/bin/bash
#
# Update dotfiles and tools

set -e

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step() { echo -e "${BLUE}➜${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

echo ""
step "Updating dotfiles"
echo ""

# Update dotfiles repo
step "Pulling latest changes"
git -C ~/.dotfiles pull origin main
success "Dotfiles updated"

# Update Homebrew and packages
step "Updating Homebrew packages"
brew update
brew upgrade
#brew bundle --file=~/.dotfiles/config/Brewfile
brew cleanup
success "Homebrew packages updated"

# Update npm packages for all fnm Node versions
step "Updating npm global packages for all Node versions"

eval "$(fnm env --use-on-cd)"

fnm list | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | while read version; do
  step "  → Node $version"
  fnm use "$version" && npm update -g --loglevel=error
  success "  ✓ Node $version updated"
done

success "All Node versions updated"

# Update global Composer packages
step "Updating global Composer packages"
composer global update
success "Composer packages updated"

# Reload shell config
echo ""
success "Update complete!"
echo ""
warn "Restart your terminal or run: exec zsh"
echo ""